{
	"name": "df_gold_dim_paquete",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "srcPlataSupCatalogoPaquetes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold_dim_paquete",
						"type": "DatasetReference"
					},
					"name": "sinkGoldDimPaquete"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(6,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcPlataSupCatalogoPaquetes",
				"srcPlataSupCatalogoPaquetes aggregate(groupBy(paquete_id),",
				"     nombre = first(nombre),",
				"          contenido = first(contenido),",
				"          peso_estandar_kg = first(peso_estandar_kg),",
				"          costo_estimado_bs = first(costo_estimado_bs)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_key as integer,",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(6,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sinkGoldDimPaquete"
			]
		}
	}
}