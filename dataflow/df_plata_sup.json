						"type": "DatasetReference"
					},
					"name": "srcbronceestablecimientos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "sinksupinscripciones"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_controles",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "sink"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "sink3"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_plata_sup_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink4"
				}
			],
			"transformations": [
				{
					"name": "derSupInscripciones"
				},
				{
					"name": "derSupControles"
				},
				{
					"name": "derSupBoletas"
				},
				{
					"name": "derSupEntregas"
				},
				{
					"name": "derSupCatalogoPaquetes"
				},
				{
					"name": "derSupEstablecimientos"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcBronceSupInscripciones",
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcBroncecontroles",
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbroncesupboletas",
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronceentregas",
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbroncecatalogopaquetes",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcbronceestablecimientos",
				"srcBronceSupInscripciones derive(inscripcion_id = toInteger(inscripcion_id),",
				"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_inscripcion = toDate(fecha_inscripcion, 'dd/MM/yyyy'),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          estado = initCap(lower(trim(estado)))) ~> derSupInscripciones",
				"srcBroncecontroles derive(control_id = toInteger(control_id),",
				"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = coalesce(toDate(fecha_control, 'yyyy-MM-dd'), toDate(fecha_control, 'MM/dd/yyyy'), toDate(fecha_control, 'dd/MM/yyyy')),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          peso_madre_kg = toDecimal(peso_madre_kg, 6, 2),",
				"          presion_arterial = iif(isNull(presion_arterial) || trim(presion_arterial) == '', toString(null()), trim(presion_arterial))) ~> derSupControles",
				"srcbroncesupboletas derive(boleta_id = toInteger(boleta_id),",
				"          control_id = toInteger(control_id),",
				"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          nro_boleta = trim(nro_boleta),",
				"          fecha_emision = coalesce(toDate(fecha_emision, 'yyyy-MM-dd'), toDate(fecha_emision, 'MM/dd/yyyy'), toDate(fecha_emision, 'dd/MM/yyyy')),",
				"          estado = upper(trim(estado))) ~> derSupBoletas",
				"srcbronceentregas derive(entrega_id = toInteger(entrega_id),",
				"          boleta_id = toInteger(boleta_id),",
				"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          paquete_id = toInteger(paquete_id),",
				"          paquete_nombre = initCap(lower(trim(paquete_nombre))),",
				"          fecha_entrega = coalesce(toDate(fecha_entrega, 'yyyy-MM-dd'), toDate(fecha_entrega, 'MM/dd/yyyy'), toDate(fecha_entrega, 'dd/MM/yyyy')),",
				"          lote_produccion = iif(isNull(lote_produccion) || trim(lote_produccion) == '', toString(null()), trim(lote_produccion)),",
				"          peso_paquete_kg = toDecimal(peso_paquete_kg, 6, 2),",
				"          fecha_proxima_entrega = coalesce(toDate(fecha_proxima_entrega, 'yyyy-MM-dd'), toDate(fecha_proxima_entrega, 'MM/dd/yyyy'), toDate(fecha_proxima_entrega, 'dd/MM/yyyy'))) ~> derSupEntregas",
				"srcbroncecatalogopaquetes derive(paquete_id = toInteger(paquete_id),",
				"          nombre = initCap(lower(trim(nombre))),",
				"          contenido = initCap(lower(trim(contenido))),",
				"          peso_estandar_kg = toDecimal(peso_estandar_kg, 6, 2),",
				"          costo_estimado_bs = toDecimal(costo_estimado_bs, 10, 2)) ~> derSupCatalogoPaquetes",
				"srcbronceestablecimientos derive(establecimiento_id = toInteger(establecimiento_id),",
				"          codigo_snis = upper(trim(codigo_snis)),",
				"          nombre = initCap(lower(trim(nombre))),",
				"          tipo = initCap(lower(trim(tipo))),",
				"          nivel_atencion = initCap(lower(trim(nivel_atencion))),",
				"          municipio = initCap(lower(trim(municipio))),",
				"          departamento = initCap(lower(trim(departamento))),",
				"          red_salud = initCap(lower(trim(red_salud))),",
				"          estado = initCap(lower(trim(estado)))) ~> derSupEstablecimientos",
				"derSupInscripciones sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinksupinscripciones",
				"derSupControles sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(6,2),",
				"          presion_arterial as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"derSupBoletas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as integer,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink",
				"derSupEntregas sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(6,2),",
				"          fecha_proxima_entrega as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2",
				"derSupCatalogoPaquetes sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(6,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink3",
				"derSupEstablecimientos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as integer,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink4"
			]
		}
	}
}