{
	"name": "df_gold_hechos_pagos",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_plata_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "srcPlataBjaPagos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold_hechos_pagos",
						"type": "DatasetReference"
					},
					"name": "sinkGoldHechosPagos"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcPlataBjaPagos",
				"srcPlataBjaPagos aggregate(groupBy(pago_id),",
				"     ci_beneficiaria = first(ci_beneficiaria),",
				"          fecha_pago = first(fecha_pago),",
				"          concepto_pago = first(concepto_pago),",
				"          monto_bs = first(monto_bs),",
				"          estado_pago = first(estado_pago),",
				"          canal_pago = first(canal_pago)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_key as integer,",
				"          tiempo_key as integer,",
				"          persona_key as integer,",
				"          pago_id as integer,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          estado_pago as string,",
				"          canal_pago as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkGoldHechosPagos"
			]
		}
	}
}