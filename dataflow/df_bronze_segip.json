{
	"name": "df_bronze_segip",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_segip",
						"type": "DatasetReference"
					},
					"name": "srcSegipCsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_bronce_segip_personas",
						"type": "DatasetReference"
					},
					"name": "sinkBronceSegip"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          CI as string,",
				"          Nombres as string,",
				"          {Ap. Paterno} as string,",
				"          {Ap. Materno} as string,",
				"          {Fecha Nac.} as string,",
				"          {Género} as string,",
				"          {Estado Civil} as string,",
				"          Municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcSegipCsv",
				"srcSegipCsv sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci = CI,",
				"          nombres = Nombres,",
				"          apellido_paterno = {Ap. Paterno},",
				"          apellido_materno = {Ap. Materno},",
				"          fecha_nacimiento = {Fecha Nac.},",
				"          genero = {Género},",
				"          estado_civil = {Estado Civil},",
				"          municipio_residencia = Municipio",
				"     )) ~> sinkBronceSegip"
			]
		}
	}
}