				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkPlataBjaPagos",
				"derBjaEstablecimientos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
